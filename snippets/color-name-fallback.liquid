{%- doc -%}
  Maps a color name to a hex value for fallback swatch rendering
  when native Shopify swatch data is not configured.
  Outputs the hex color string (e.g., "#000000") or blank if unknown.

  @param {string} color_name - The color option value name (e.g., "Forest Green")

  @example
  {%- capture fallback_hex -%}{% render 'color-name-fallback', color_name: product_option_value.name %}{%- endcapture -%}
{%- enddoc -%}

{%- liquid
  assign normalized = color_name | downcase | strip

  case normalized
    when 'black'
      echo '#000000'
    when 'white'
      echo '#FFFFFF'
    when 'red'
      echo '#CC0000'
    when 'blue'
      echo '#0000CC'
    when 'navy', 'navy blue'
      echo '#001F3F'
    when 'forest green'
      echo '#228B22'
    when 'green'
      echo '#008000'
    when 'sport grey', 'sports grey', 'sport gray', 'sports gray'
      echo '#90908E'
    when 'grey', 'gray'
      echo '#808080'
    when 'light grey', 'light gray'
      echo '#C0C0C0'
    when 'dark grey', 'dark gray', 'charcoal'
      echo '#333333'
    when 'heather grey', 'heather gray'
      echo '#9B9B9B'
    when 'dark heather'
      echo '#545454'
    when 'maroon'
      echo '#800000'
    when 'burgundy'
      echo '#722F37'
    when 'pink'
      echo '#FFC0CB'
    when 'hot pink'
      echo '#FF69B4'
    when 'orange'
      echo '#FF6600'
    when 'yellow'
      echo '#FFD700'
    when 'gold'
      echo '#DAA520'
    when 'purple'
      echo '#800080'
    when 'royal blue'
      echo '#4169E1'
    when 'light blue'
      echo '#ADD8E6'
    when 'sky blue'
      echo '#87CEEB'
    when 'teal'
      echo '#008080'
    when 'olive'
      echo '#808000'
    when 'tan', 'sand'
      echo '#D2B48C'
    when 'brown'
      echo '#8B4513'
    when 'cream', 'ivory'
      echo '#FFFDD0'
    when 'coral'
      echo '#FF7F50'
    when 'salmon'
      echo '#FA8072'
    when 'mint'
      echo '#98FF98'
    when 'lavender'
      echo '#E6E6FA'
    when 'indigo'
      echo '#4B0082'
    when 'khaki'
      echo '#C3B091'
    when 'natural'
      echo '#F5F5DC'
    when 'military green'
      echo '#4B5320'
    when 'ash'
      echo '#B2BEB5'
    when 'dark navy'
      echo '#000080'
    when 'heather sport dark navy'
      echo '#1C2841'
    when 'light pink'
      echo '#FFB6C1'
    when 'carolina blue'
      echo '#56A0D3'
    when 'irish green'
      echo '#009A44'
    when 'safety green'
      echo '#78BE20'
    when 'safety orange'
      echo '#FF6700'
    when 'sand dune'
      echo '#967117'
    when 'sapphire'
      echo '#0F52BA'
  endcase
-%}
